# ADUAtlas environment configuration. Copy to `.env.local` and fill in.
# Leave any var blank to disable that integration; the app falls back to
# localStorage / mock flows in development.

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon (public) key from https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── PostHog analytics ───────────────────────────────────────────────────────
# Project API key from https://posthog.com → Project Settings
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Stripe Checkout ─────────────────────────────────────────────────────────
# Endpoint that creates a Checkout Session and returns { url }. Vercel-style
# function lives at /api/create-checkout; override here if hosted elsewhere.
VITE_CHECKOUT_ENDPOINT=/api/create-checkout

# Endpoint that verifies a completed Checkout Session server-side (confirms
# Stripe payment_status === "paid") and returns { paid, tier }. /welcome calls
# this on the real Stripe success_url (?session_id=) before flipping local
# access. Leave blank in dev to use the mock flow (?mock=1).
VITE_VERIFY_ENDPOINT=/api/verify-session

# Backend-only (NOT VITE_-prefixed; consumed by the serverless function)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ROADMAP=price_...      # $99 ADU Build Prepared course
# STRIPE_PRICE_REPORT=price_...       # $399 Property Feasibility Report
# STRIPE_PRICE_CONCIERGE=price_...    # internal only
# Stripe coupon id that takes $99 off the $399 Report for buyers who already
# bought the $99 roadmap tier (the "Build Prepared credit"). Optional — if
# unset, report checkout falls back to full price without error.
# STRIPE_COUPON_ROADMAP_CREDIT=
# SUPABASE_URL=                       # server-side; can mirror VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=          # service role (NOT anon) for upserts/lookups

# ── Mapbox (address autocomplete) ───────────────────────────────────────────
# Public token from https://account.mapbox.com → Tokens
VITE_MAPBOX_TOKEN=

# ── Property data (lot size, building size) ─────────────────────────────────
# Set the endpoint to enable real lookups on /property; the serverless function
# at /api/property-lookup proxies a provider and keeps the key server-side.
# Leave the endpoint blank to show example data.
VITE_PROPERTY_LOOKUP_ENDPOINT=/api/property-lookup
# Backend-only (consumed by the serverless function):
# PROPERTY_API_PROVIDER=rentcast
# RENTCAST_API_KEY=                 # free tier ~50/mo at https://app.rentcast.io

# ── Resend (transactional + nurture email) ─────────────────────────────────
# Backend-only; consumed by the email-send serverless function
# RESEND_API_KEY=re_...
# RESEND_FROM=hello@aduatlas.com
